{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run MAF Workflow Studio",
      "type": "shell",
      "command": "${command:python.interpreterPath} -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".*",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Application startup complete|Uvicorn running on"
        }
      }
    }
  ]
}
